{
  "manifest_version": 3,
  "name": "ProspectorAI - Multi-Network Automation",
  "version": "1.0.0",
  "description": "Automatiza tu prospección en LinkedIn, Fiverr, Twitter, Instagram y más",
  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.fiverr.com/*",
    "https://twitter.com/*",
    "https://x.com/*",
    "https://www.instagram.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content-scripts/linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.fiverr.com/*"],
      "js": ["content-scripts/fiverr.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ProspectorAI"
  }
}
